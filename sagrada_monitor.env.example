# 예시 환경 파일 (.env)
##
# 이 파일은 `sagrada_monitor.py` 스크립트가 참조하는 환경변수의 예시입니다.
# 필요에 따라 실제 토큰과 ID로 값을 수정한 후 파일명을 `.env`로 변경하여 사용하세요.

# 결제 카드 정보 (booking_assistant.py가 config.py를 통해 읽음)
# ⚠️ 실제 .env에만 넣고 커밋 금지. config.py에는 평문으로 두지 마세요.
#CARD_NUMBER=4617230014437966
#CARD_EXP_MONTH=01
#CARD_EXP_YEAR=31
#CARD_CVV=229
#CARD_HOLDER=Taekyung Kim

# 텔레그램 알림 설정
# BotFather를 통해 생성한 봇의 토큰을 입력합니다.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjkLmNoPQRSTuVwxYZ

# 알림을 받을 채팅 ID를 입력합니다.
# 개인 채팅의 경우 본인의 사용자 ID, 그룹 채팅의 경우 그룹 ID입니다.
TELEGRAM_CHAT_ID=987654321

# 선택: 이메일 알림 설정 – 사용하지 않으면 주석 처리하거나 비워두어도 됩니다.
#EMAIL_HOST=smtp.example.com
#EMAIL_PORT=587
#EMAIL_USER=your_email@example.com
#EMAIL_PASSWORD=your_email_password
#EMAIL_TO=recipient@example.com

# 선택: 스크립트 매개변수 재정의
# 모니터링할 날짜 목록을 쉼표로 구분하여 입력합니다. 스크립트에서 환경변수로 읽도록 수정할 경우 사용합니다.
#TARGET_DATES=2026-07-05,2026-07-06,2026-07-07,2026-07-08,2026-07-09

# 확인 주기(초). 기본값은 300초(5분)입니다.
#CHECK_INTERVAL=300

# 스크립트 동작 모드 설정
# HEADLESS=1   # 브라우저를 보이지 않는(headless) 모드로 실행 (기본값)
# HEADLESS=0   # 브라우저 창을 띄워 실제 동작을 볼 수 있도록 실행

# 로그 레벨 설정
# LOG_LEVEL=INFO   # 일반 정보 수준의 로그 출력
# LOG_LEVEL=DEBUG  # 디버깅 정보를 포함한 자세한 로그 출력